rules_version = '2';

// Firestore Security Rules — VidyaPath
//
// Deploy with: firebase deploy --only firestore:rules
//
// Model:
//  - Syllabus content (subjects, chapters, resources, _meta) is public READ,
//    admin-only WRITE.
//  - Per-user data (users/{uid}, progress/{uid}/**, notes/{uid}/**) is
//    readable and writable ONLY by the signed-in owner.
//  - Admin writes require the caller's auth token to carry a custom claim
//    `admin: true`. Set this via the Firebase Admin SDK; never trust the
//    client to self-declare admin status.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Public syllabus content — read by anyone, write by admins only.
    match /subjects/{subjectId} {
      allow read: if true;
      allow write: if isAdmin();

      match /chapters/{chapterId} {
        allow read: if true;
        allow write: if isAdmin();

        match /resources/{resourceId} {
          allow read: if true;
          allow write: if isAdmin();
        }
      }
    }

    match /_meta/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Per-user profile.
    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Per-user progress.
    match /progress/{uid} {
      allow read, write: if isOwner(uid);
      match /{document=**} {
        allow read, write: if isOwner(uid);
      }
    }

    // Per-user notes.
    // Notes are stored in a flat collection keyed by note id, with a
    // `userId` field identifying the owner. Reads/writes require the
    // caller to be the owner of the existing document (for updates/deletes)
    // and the incoming document (for creates/updates).
    match /notes/{noteId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Per-user chapter progress. Flat collection keyed by `${userId}_${chapterId}`
    // with a `userId` field. Only the owning user may read or write.
    match /chapterProgress/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Aggregate per-user progress snapshot. Doc id == userId.
    match /userProgress/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && request.resource.data.userId == uid;
      allow update, delete: if isOwner(uid)
        && resource.data.userId == uid
        && request.resource.data.userId == uid;
    }

    // Study session log. Flat collection, owner-gated by `userId` field.
    match /studySessions/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Unlocked achievements. Doc id convention: `${userId}_${code}`.
    match /achievements/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Daily analytics rollup. Doc id convention: `${userId}_${dayKey}`.
    match /analytics/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}