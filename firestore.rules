rules_version = '2';

// Firestore Security Rules — VidyaPath
//
// Deploy with: firebase deploy --only firestore:rules
//
// Model:
//  - Syllabus content (subjects, chapters, resources, _meta) is public READ,
//    admin-only WRITE.
//  - Per-user data (users/{uid}, progress/{uid}/**, notes/{uid}/**) is
//    readable and writable ONLY by the signed-in owner.
//  - Admin writes require the caller's auth token to carry a custom claim
//    `admin: true`. Set this via the Firebase Admin SDK; never trust the
//    client to self-declare admin status.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Public syllabus content — read by anyone, write by admins only.
    match /subjects/{subjectId} {
      allow read: if true;
      allow write: if isAdmin();

      match /chapters/{chapterId} {
        allow read: if true;
        allow write: if isAdmin();

        match /resources/{resourceId} {
          allow read: if true;
          allow write: if isAdmin();
        }
      }
    }

    match /_meta/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Flat syllabus collections actually used by the app code
    // (see COLLECTIONS in src/integrations/firebase/config.ts).
    // Public read, admin-only write — same posture as the nested
    // /subjects/** content above.
    match /chapters/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /resources/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mcqs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Quiz definitions — public read, admin-only write. Same posture as the
    // mcqs catalog above.
    match /quizzes/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Per-user profile.
    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Weakness Diagnosis & Adaptive Remediation Engine — per-user
    // subcollections under users/{uid}. Owner read/write only.
    match /users/{uid}/performance/{recordId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/weaknesses/{chapterId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/remediation/{planId} {
      allow read, write: if isOwner(uid);
    }

    // Cohort-level chapter intelligence — public read, admin-only write.
    // Lives at chapters/{chapterId}/intelligence/{summaryId}.
    match /chapters/{chapterId}/intelligence/{summaryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Adaptive Study Planner & Intervention Engine — per-user subcollections
    // under users/{uid}. Owner read/write only.
    match /users/{uid}/interventionPlans/{planId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/adaptiveSchedules/{scheduleId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/revisionQueue/{queueId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/remediationSessions/{sessionId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/memoryTracking/{chapterId} {
      allow read, write: if isOwner(uid);
    }

    // GPT/Gemini Semantic Reasoning Layer — per-user subcollections
    // under users/{uid}. Owner read/write only. Public chapter reads
    // and admin seeding rules remain unchanged.
    match /users/{uid}/aiTutoringSessions/{sessionId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/semanticEvaluations/{evaluationId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/hintHistory/{hintId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/reasoningFeedback/{feedbackId} {
      allow read, write: if isOwner(uid);
    }

    // Board Readiness Prediction + Exam Simulation Engine —
    // per-user subcollections under users/{uid}. Owner read/write only.
    // Public chapter reads and admin seeding rules remain unchanged.
    match /users/{uid}/examSimulations/{simulationId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/boardReadiness/{readinessId} {
      allow read, write: if isOwner(uid);
    }

    // Per-user profile (auth + onboarding metadata). Doc id == auth uid.
    match /userProfiles/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Per-user app settings. Doc id == auth uid.
    match /userSettings/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Per-user aggregated stats. Doc id == auth uid.
    match /userStats/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Per-user progress.
    match /progress/{uid} {
      allow read, write: if isOwner(uid);
      match /{document=**} {
        allow read, write: if isOwner(uid);
      }
    }

    // Per-user notes.
    // Notes are stored in a flat collection keyed by note id, with a
    // `userId` field identifying the owner. Reads/writes require the
    // caller to be the owner of the existing document (for updates/deletes)
    // and the incoming document (for creates/updates).
    match /notes/{noteId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Per-user chapter progress. Flat collection keyed by `${userId}_${chapterId}`
    // with a `userId` field. Only the owning user may read or write.
    match /chapterProgress/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Aggregate per-user progress snapshot. Doc id == userId.
    match /userProgress/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && request.resource.data.userId == uid;
      allow update, delete: if isOwner(uid)
        && resource.data.userId == uid
        && request.resource.data.userId == uid;
    }

    // Study session log. Flat collection, owner-gated by `userId` field.
    match /studySessions/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Public achievement catalog (definition docs: title, description, xp).
    // Read by anyone (used to render locked badges before sign-in too);
    // write only by admins via the Firebase Admin SDK.
    match /achievements/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Per-user unlocked achievements. Doc id: `${userId}_${code}`.
    match /userAchievements/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Per-user streak ledger. Doc id == userId.
    match /streaks/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && request.resource.data.userId == uid;
      allow update, delete: if isOwner(uid)
        && resource.data.userId == uid
        && request.resource.data.userId == uid;
    }

    // Daily analytics rollup. Doc id convention: `${userId}_${dayKey}`.
    match /analytics/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Per-user quiz attempts. Owner-gated by `userId` field. Reads scope
    // server-side leaderboards (future) via collectionGroup queries.
    match /quizAttempts/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Per-user generated study plans (daily / weekly). Owner-gated.
    match /studyPlans/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Per-user planner tasks. Owner-gated by `userId` field.
    match /plannerTasks/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Per-user spaced-repetition cards. Doc id: `${userId}_${chapterId}`.
    match /revisionSchedules/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Per-user AI recommendations. Owner-gated by `userId` field.
    match /recommendations/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Per-user AI insight rollups. Doc id: `${userId}_${scope}_${periodKey}`.
    match /aiInsights/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Mock exam catalog — public read, admin-only write.
    match /mockExams/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Per-user exam attempts (in-progress + finished). Owner-gated.
    match /examAttempts/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Per-user exam result rollups (analytics snapshot). Owner-gated.
    match /examResults/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Daily AI Study Engine — owner-gated by `userId` field.
    match /dailyPlans/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }
    match /dailyReflections/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }
    match /motivationEvents/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Structured academic content — public read, admin-only write.
    // Stores lightweight metadata + external links (no embedded PDFs).
    match /syllabusContent/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /chapterResources/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /textbookLinks/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /chapterNotes/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Centralized library — public read, admin-only write.
    match /libraryResources/{docId} {
      allow read: if true;
      // Anyone signed-in may bump the view counter; admins may write any field.
      allow update: if isAdmin()
        || (isSignedIn()
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(["views"]));
      allow create, delete: if isAdmin();
    }

    match /libraryCategories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Handwritten answer uploads — per-image record. Owner-gated by `userId`.
    match /answerUploads/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Handwritten answer submission session — owner-gated by `userId`.
    match /answerAttempts/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // AI evaluation of handwritten answers — owner-gated by `userId` field.
    // Doc id == attemptId for O(1) lookup from the review screen.
    match /evaluations/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Per-user rolling weakness rollup. Doc id: `${userId}_${subjectId}[_${chapterId}]`.
    match /weaknessReports/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Curated reference data — public read, admin-only write.
    match /modelAnswers/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /evaluationRubrics/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Mathematics Intelligence System — reference data is public read,
    // admin-only write. Per-user analytics is owner-gated.
    match /mathChapters/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /mathQuestions/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /mathModelAnswers/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /mathFormulas/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /mathRubrics/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /mathKeywords/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /mathCommonMistakes/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Per-user, per-chapter math analytics. Doc id: `${userId}_${chapterId}`.
    match /mathChapterAnalytics/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Math academic data import drafts — admin-only read/write. Lets reviewers
    // approve queued imports before they hit live student-facing collections.
    match /mathImportDrafts/{docId} {
      allow read, write: if isAdmin();
    }

    // Study Session Experience — owner-gated by `userId` field.
    match /sessionResults/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }
    match /sessionFeedback/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }
    match /revisionTriggers/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // AI Scan & Solve — owner-gated by `userId` field.
    match /scans/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }
    match /solvedQuestions/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }
    match /aiEvaluations/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }
    match /practiceRecommendations/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // Continuous Learning Memory + Tutoring Continuity Engine —
    // per-user subcollections under users/{uid}. Owner read/write only.
    match /users/{uid}/learningProfile/{docId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/mistakeMemory/{docId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/tutoringPreferences/{docId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/learningTimeline/{docId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/scanHistory/{docId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/conceptConfidence/{docId} {
      allow read, write: if isOwner(uid);
    }

    // Gamification + Student Reward System — owner-gated per-user subcollections.
    match /users/{uid}/xp/{docId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/levels/{docId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/missions/{docId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/streaks/{docId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/rewardHistory/{docId} {
      allow read, write: if isOwner(uid);
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}