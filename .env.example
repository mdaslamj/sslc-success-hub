SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_URL=""
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""

# Firebase (Aura) — publishable web config, safe to expose in the client bundle.
# Find these in Firebase Console → Project settings → Your apps → Web app config.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# Runtime-only secrets — configured via Lovable Cloud → Secrets, NOT in .env.
# They must NOT use the VITE_ prefix or they would be inlined into the client bundle.
#   ADMIN_ACCESS_CODE       — admin gate pass-phrase
#   ADMIN_SESSION_SECRET    — >=32 char random string for cookie encryption
#   FIREBASE_PROJECT_ID     — MUST match VITE_FIREBASE_PROJECT_ID (e.g. "aura-57e48").
#                             Used server-side to verify the issuer/audience claims
#                             on incoming Firebase ID tokens. If unset or stale,
#                             all authenticated AI calls will fail with 401.
